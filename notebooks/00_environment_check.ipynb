    "print(sys.executable)\n",
    "print(np.__version__)\n",
    "\n",
    "x = np.linspace(-5, 5, 200)\n",
    "y = np.sin(x)\n",
    "\n",
    "plt.plot(x, y)\n",
    "plt.xlabel(\"x\")\n",
    "plt.ylabel(\"sin(x)\")\n",
    "plt.title(\"Jupyter notebook test\")\n",
    "plt.show()"
